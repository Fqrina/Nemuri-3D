{
  "nodes": [
    {
      "speaker": "Narrator",
      "text": "You find a purple Energeon kneeling in the middle of the path, clutching her head in pain.",
      "portraitName": "",
      "typingSpeed": 0.05
    },
    {
      "speaker": "Rona",
      "text": "Keiko!",
      "portraitName": "Rona",
      "typingSpeed": 0.05
    },
    {
      "speaker": "Keiko",
      "text": "My head hurts so much... It's ringing...",
      "portraitName": "Keiko",
      "typingSpeed": 0.05
    },
    {
      "speaker": "Murial",
      "text": "It's getting worse...",
      "portraitName": "Murial",
      "typingSpeed": 0.05
    },
    {
      "speaker": "Kael",
      "text": "What is happening...?",
      "portraitName": "Kael",
      "typingSpeed": 0.05
    },
    {
      "speaker": "Rona",
      "text": "Are you okay?",
      "portraitName": "Rona",
      "typingSpeed": 0.05
    },
    {
      "speaker": "Keiko",
      "text": "I'm okay now...",
      "portraitName": "Keiko",
      "typingSpeed": 0.05
    },
    {
      "speaker": "Keiko",
      "text": "Kael?",
      "portraitName": "Keiko",
      "typingSpeed": 0.05
    },
    {
      "speaker": "Kael",
      "text": "How does everyone know me?",
      "portraitName": "Kael",
      "typingSpeed": 0.05
    },
    {
      "speaker": "Rona",
      "text": "I don't know how you got here, but... you're inside your own mind.",
      "portraitName": "Rona",
      "typingSpeed": 0.05
    },
    {
      "speaker": "Keiko",
      "text": "We are your Energeons. We represent your energies, Kael.",
      "portraitName": "Keiko",
      "typingSpeed": 0.05
    },
    {
      "speaker": "Kael",
      "text": "What...?",
      "portraitName": "Kael",
      "typingSpeed": 0.05
    },
    {
      "speaker": "Murial",
      "text": "It's going to be hard to explain. You probably wouldn't understand it yet. But what you need to know is that this world is falling apart because you haven't been taking care of yourself.",
      "portraitName": "Murial",
      "typingSpeed": 0.05
    },
    {
      "speaker": "Rona",
      "text": "Calm down, Murial...",
      "portraitName": "Rona",
      "typingSpeed": 0.05
    },
    {
      "speaker": "Murial",
      "text": "I—",
      "portraitName": "Murial",
      "typingSpeed": 0.05
    },
    {
      "speaker": "Keiko",
      "text": "Guys... I hear it!",
      "portraitName": "Keiko",
      "typingSpeed": 0.05
    },
    {
      "speaker": "Rona",
      "text": "Then let's go.",
      "portraitName": "Rona",
      "typingSpeed": 0.05
    },
    {
      "speaker": "Objective",
      "text": "Follow Keiko.",
      "portraitName": "",
      "typingSpeed": 0.05
    }
  ]
}
