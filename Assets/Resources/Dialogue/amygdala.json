{
  "nodes": [
    {
      "speaker": "Rona",
      "text": "No, no, NO!",
      "portraitName": "Rona",
      "typingSpeed": 0.05
    },
    {
      "speaker": "Rona",
      "text": "It’s all ruined!",
      "portraitName": "Rona",
      "typingSpeed": 0.05
    },
    {
      "speaker": "Murial",
      "text": "It’s because of you Kael!",
      "portraitName": "Murial",
      "typingSpeed": 0.05
    },
    {
      "speaker": "Kael",
      "text": "Why are you blaming me?",
      "portraitName": "Kael",
      "typingSpeed": 0.05
    },
    {
      "speaker": "Murial",
      "text": "And why can’t you just stop running away and ruining yourself?",
      "portraitName": "Murial",
      "typingSpeed": 0.05
    },
    {
      "speaker": "Keiko",
      "text": "(Cry) Please don’t fight…",
      "portraitName": "Keiko",
      "typingSpeed": 0.05
    },
    {
      "speaker": "Feanor",
      "text": "Look at the Nocturne Heart.",
      "portraitName": "Feanor",
      "typingSpeed": 0.05
